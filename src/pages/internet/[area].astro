.btn{display:inline-block;background:var(--teal);color:#fff;padding:13px 26px;border-radius:10px;font-weight:600;font-size:15px}
.btn:hover{background:#0C6564}
.hero{background:radial-gradient(ellipse at 72% 8%,rgba(92,184,178,.07),transparent 42%),linear-gradient(180deg,#04080A 0%,#081013 45%,#0B181C 75%,#12333A 100%),var(--night);color:#fff;padding:96px 0 88px;position:relative;overflow:hidden}
.stars{position:absolute;top:0;left:0;z-index:1;pointer-events:none}
.hero .wrap{position:relative;z-index:2}
.crumb{font-size:13px;color:#7E9391;margin-bottom:18px}
.crumb a{color:var(--teal-lt)}
.pill{display:inline-flex;align-items:center;gap:8px;border:1px solid rgba(92,184,178,.4);color:var(--teal-lt);border-radius:20px;padding:6px 14px;font-size:13px;font-weight:500;margin-bottom:20px}
.pill i{width:8px;height:8px;border-radius:4px;background:var(--amber)}
.hero h1{font-size:clamp(34px,5vw,58px);line-height:1.08;max-width:820px;letter-spacing:-.01em}
.hero p{margin:20px 0 30px;color:#AFC2C0;max-width:680px;font-size:17.5px}
section{padding:96px 0}
h2{font-size:clamp(24px,3vw,32px);margin-bottom:18px;color:var(--ink)}
.estates{display:flex;flex-wrap:wrap;gap:10px;max-width:920px;margin:8px 0 26px}
.estate{border:1.5px solid var(--line);background:#fff;border-radius:24px;padding:11px 22px;font-size:14px;font-weight:500;display:flex;align-items:center;gap:8px}
.estate i{width:7px;height:7px;border-radius:4px;background:var(--amber)}
.pgrid{display:grid;grid-template-columns:repeat(auto-fit,minmax(230px,1fr));gap:24px}
.plan{border:1.5px solid var(--line);border-radius:16px;padding:22px;background:#fff}
.plan .nm{font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:15px;color:var(--muted)}
.plan .pr{font-family:'Space Grotesk',sans-serif;font-size:26px;font-weight:600;margin:6px 0 2px}
.plan .pr small{font-size:13px;color:var(--muted);font-weight:400}
