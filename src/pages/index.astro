<style is:global>
:root{
  --night:#0A1214; --night2:#0E181B; --teal:#0F7B7A; --teal-lt:#5CB8B2;
  --amber:#FFB224; --paper:#FBFAF7; --ink:#101B1F; --tint:#68ABA9;
  --line:#E3E0D7; --muted:#5B6A6D;
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
section[id],header[id]{scroll-margin-top:78px}
body{font-family:'Inter',system-ui,sans-serif;background:var(--paper);color:var(--ink);line-height:1.6;font-size:16px}
h1,h2,h3,.sg{font-family:'Space Grotesk',sans-serif}
a{color:inherit;text-decoration:none}
.wrap{max-width:1280px;margin:0 auto;padding:0 clamp(24px,4vw,48px)}
.eyebrow{font-family:'Space Grotesk';font-size:12px;letter-spacing:.24em;text-transform:uppercase;color:var(--teal);font-weight:500;margin-bottom:14px}
.btn{display:inline-block;background:var(--teal);color:#fff;padding:13px 26px;border-radius:10px;font-weight:600;font-size:15px;border:none;cursor:pointer;transition:background .2s}
.btn:hover{background:#0C6564}
.btn.ghost{background:transparent;border:1.5px solid var(--teal-lt);color:var(--teal-lt)}
.btn.ghost:hover{background:rgba(92,184,178,.12)}
:focus-visible{outline:2.5px solid var(--teal-lt);outline-offset:2px}

/* ---------- nav ---------- */
nav{position:sticky;top:0;z-index:50;background:rgba(7,14,16,.92);backdrop-filter:blur(12px);border-bottom:1px solid rgba(255,255,255,.06)}
.navin{display:flex;align-items:center;justify-content:space-between;height:66px}
.logo{display:flex;align-items:center;gap:12px}
.logo svg{display:block}
.navlinks{display:flex;gap:26px;align-items:center}
.navlinks a{color:#B9C7C5;font-size:14.5px;font-weight:500}
.navlinks a:hover{color:#fff}
.navlinks .btn{padding:9px 18px;font-size:14px}
.burger{display:none;background:none;border:none;cursor:pointer;padding:8px}
.burger span{display:block;width:22px;height:2px;background:#fff;margin:5px 0;border-radius:2px}

/* ---------- hero ---------- */
.hero{background:radial-gradient(ellipse at 72% 8%,rgba(92,184,178,.07),transparent 42%),radial-gradient(ellipse at 25% 30%,rgba(15,123,122,.05),transparent 50%),linear-gradient(180deg,#04080A 0%,#081013 45%,#0B181C 75%,#12333A 100%),var(--night);color:#fff;position:relative;overflow:hidden}
.stars{position:absolute;top:0;left:0;z-index:1;pointer-events:none}
@keyframes twinkle{0%,100%{opacity:var(--o)}50%{opacity:calc(var(--o)*0.3)}}
.hero .wrap{position:relative;z-index:2;padding-top:120px;padding-bottom:150px}
.pricemoment{margin:30px 0 34px}
.pk{font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:rgba(214,228,226,.55);font-family:'Space Grotesk',sans-serif}
.pv{font-family:'Space Grotesk',sans-serif;font-size:clamp(34px,3.2vw,46px);font-weight:600;color:#EAF4F2;line-height:1.15;margin-top:2px}
.pv small{font-size:19px;font-weight:500;color:rgba(214,228,226,.6)}
.pl{font-size:14.5px;color:rgba(214,228,226,.65);margin-top:3px}
.hero h1{font-size:clamp(40px,6.2vw,78px);line-height:1.03;font-weight:600;max-width:840px;letter-spacing:-0.022em}
.hero h1 em{font-style:normal;color:var(--teal-lt)}
.hero h1 .hdot{color:var(--amber)}
.herocta{padding:16px 30px;font-size:17px;box-shadow:0 0 28px rgba(92,184,178,.22)}
.covlink{color:var(--teal-lt);font-size:15.5px;font-weight:500}
.covlink:hover{color:#fff}
.hero p.lead{margin:22px 0 34px;font-size:clamp(17px,1.4vw,20px);color:#AFC2C0;max-width:580px}
.hero .horizon{position:absolute;bottom:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,rgba(15,123,122,.85) 18%,#15908E 50%,rgba(15,123,122,.85) 82%,transparent);z-index:2}
.hero .horizon:after{content:"";position:absolute;inset:-14px 0 0;background:linear-gradient(180deg,transparent,rgba(21,144,142,.14));pointer-events:none}

/* ---------- trust strip ---------- */
.trust{background:rgba(255,255,255,.02);background-color:var(--night2);color:#8FA6A3}
.trust .wrap{display:flex;gap:8px 34px;flex-wrap:wrap;justify-content:center;padding:24px;font-size:13.5px;font-weight:500}
.trust b{color:var(--teal-lt);font-weight:600}

/* ---------- sections ---------- */
section{padding:112px 0}
.sechead{display:grid;grid-template-columns:minmax(0,1.1fr) minmax(0,.9fr);column-gap:90px;align-items:end;max-width:none;margin-bottom:56px}
.sechead .eyebrow{grid-column:1/-1;margin-bottom:6px}
.sechead h2{grid-column:1}
.sechead p{grid-column:2;justify-self:end;max-width:560px;width:100%}
.sechead h2{font-size:clamp(28px,4vw,38px);font-weight:600;line-height:1.15;margin:10px 0 12px}
.sechead p{color:var(--muted)}

/* ---------- plans ---------- */
.plans{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:24px}
.plan{border:1.5px solid var(--line);border-radius:18px;padding:32px 28px;background:#fff;position:relative;display:flex;flex-direction:column;transition:transform .2s, box-shadow .2s}
.plan:hover{transform:translateY(-4px);box-shadow:0 14px 34px rgba(16,27,31,.10)}
.plan.pop{border-color:var(--teal);border-width:2px}
.badge{position:absolute;top:-12px;left:24px;background:var(--teal);color:#fff;font-size:11px;letter-spacing:.14em;text-transform:uppercase;font-weight:600;padding:4px 12px;border-radius:20px;font-family:'Space Grotesk'}
.plan .pname{font-family:'Space Grotesk';font-weight:600;font-size:17px;display:flex;align-items:center;gap:8px;margin-bottom:16px}
.plan .pname i{width:8px;height:8px;border-radius:5px;background:var(--amber);display:inline-block}
.speed{font-family:'Space Grotesk';font-size:44px;font-weight:600;line-height:1}
.speed small{font-size:15px;font-weight:500;color:var(--muted)}
.price{margin:14px 0 4px;font-family:'Space Grotesk';font-size:22px;font-weight:600;color:var(--teal)}
.price small{font-size:13px;color:var(--muted);font-weight:400;font-family:'Inter'}
.plan ul{list-style:none;margin:16px 0 22px;flex:1}
.plan li{font-size:14px;color:#3C4A4E;padding:5px 0 5px 22px;position:relative}
.plan li:before{content:"";position:absolute;left:0;top:12px;width:12px;height:12px;border:1.5px solid var(--teal);border-radius:4px}
.plan .btn{width:100%;text-align:center}
.plannote{margin-top:22px;font-size:13.5px;color:var(--muted)}


/* ---------- plan tabs + custom slider ---------- */
.tabs{display:inline-flex;background:#fff;border:1.5px solid var(--line);border-radius:12px;padding:4px;margin-bottom:28px}
.tabs button{border:none;background:transparent;padding:9px 22px;border-radius:9px;font-family:'Space Grotesk';font-weight:600;font-size:14.5px;color:var(--muted);cursor:pointer}
.tabs button.on{background:var(--teal);color:#fff}
.pgrid{display:none}
.pgrid.on{display:grid}
.custom{margin-top:26px;border:1.5px dashed var(--teal);border-radius:18px;padding:26px 26px;background:#fff;display:flex;gap:26px;align-items:center;flex-wrap:wrap}
.custom .cl{flex:1;min-width:260px}
.custom h3{font-family:'Space Grotesk';font-size:18px;font-weight:600;margin-bottom:4px}
.custom p{font-size:13.5px;color:var(--muted);margin-bottom:16px}
.custom input[type=range]{width:100%;accent-color:var(--teal)}
.custom .cr{text-align:center;min-width:200px}
.custom .cspeed{font-family:'Space Grotesk';font-size:38px;font-weight:600;line-height:1}
.custom .cspeed small{font-size:14px;color:var(--muted)}
.custom .cprice{font-family:'Space Grotesk';font-size:19px;font-weight:600;color:var(--teal);margin:6px 0 14px}
/* ---------- honest ---------- */
.honest{background:var(--night);color:#fff}
.honest .eyebrow{color:var(--teal-lt)}
.honest .sechead p{color:#8FA6A3}
.fine{display:grid;grid-template-columns:1fr 1fr;gap:0;border:1px solid rgba(92,184,178,.25);border-radius:18px;overflow:hidden;max-width:none}
.fine>div{padding:40px 44px}
.fine .them{background:rgba(255,255,255,.03);border-right:1px solid rgba(92,184,178,.25)}
.fine h3{font-size:13px;letter-spacing:.18em;text-transform:uppercase;color:#7E9391;font-weight:500;margin-bottom:18px}
.fine .us h3{color:var(--teal-lt)}
.fine dl{display:grid;grid-template-columns:1fr auto;gap:10px 16px;font-size:14.5px}
.fine dt{color:#AFC2C0}
.fine dd{font-family:'Space Grotesk';font-weight:500;text-align:right;color:#E8D9B8}
.fine .us dd{color:var(--teal-lt)}
.fine .us dd.free{color:#fff}
@media(max-width:700px){.fine{grid-template-columns:1fr}.fine .them{border-right:none;border-bottom:1px solid rgba(92,184,178,.25)}}

/* ---------- how ---------- */
.steps{display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:24px}
.step{border:1.5px solid var(--line);border-radius:18px;padding:32px 30px;background:#fff}
.step .k{font-family:'Space Grotesk';font-size:13px;letter-spacing:.16em;color:var(--teal);text-transform:uppercase;font-weight:600}
.step h3{font-size:19px;margin:10px 0 8px;font-weight:600}
.step p{font-size:14.5px;color:var(--muted)}

/* ---------- coverage ---------- */
.areas{display:flex;flex-wrap:wrap;gap:10px;max-width:920px}
.area{border:1.5px solid var(--line);background:#fff;border-radius:24px;padding:11px 22px;font-size:14px;font-weight:500;display:flex;align-items:center;gap:9px;transition:border-color .15s}.area:hover{border-color:var(--teal)}
.area i{width:7px;height:7px;border-radius:4px;background:var(--amber)}
.area.soon{color:var(--muted)}
.area.soon i{background:var(--line)}
.covnote{margin-top:20px;font-size:14.5px;color:var(--muted)}
.covnote a{color:var(--teal);font-weight:600}

/* ---------- business ---------- */
.biz{background:var(--night);color:#fff}
.biz .wrap{display:grid;grid-template-columns:1.1fr .9fr;gap:50px;align-items:center}
.biz .eyebrow{color:var(--teal-lt)}
.biz h2{font-size:clamp(26px,3.5vw,34px);margin:10px 0 14px;font-weight:600}
.biz p{color:#AFC2C0;font-size:15.5px;margin-bottom:26px}
.biz ul{list-style:none;margin-bottom:30px}
.biz li{padding:7px 0 7px 26px;position:relative;color:#CFE0DE;font-size:15px}
.biz li:before{content:"";position:absolute;left:0;top:14px;width:13px;height:13px;border:1.5px solid var(--teal-lt);border-radius:4px}
.bizart{border:1.5px solid rgba(92,184,178,.3);border-radius:22px;padding:34px;text-align:center}
.bizart .big{font-family:'Space Grotesk';font-size:56px;font-weight:600;color:var(--teal-lt)}
.bizart .lbl{font-size:13px;color:#7E9391;letter-spacing:.14em;text-transform:uppercase;margin-top:6px}
.bizart hr{border:none;border-top:1px solid rgba(92,184,178,.2);margin:24px 0}
@media(max-width:820px){.biz .wrap{grid-template-columns:1fr}}

/* ---------- faq ---------- */
.faq{max-width:none;display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:0 88px;align-items:start}
details{border-bottom:1px solid var(--line);padding:24px 0}
summary{cursor:pointer;font-family:'Space Grotesk';font-weight:500;font-size:17px;list-style:none;display:flex;justify-content:space-between;align-items:center;gap:16px}
summary::-webkit-details-marker{display:none}
summary:after{content:"+";font-size:22px;color:var(--teal);flex-shrink:0}
details[open] summary:after{content:"–"}
details p{margin-top:12px;color:var(--muted);font-size:15px}

/* ---------- footer ---------- */
footer{background:var(--night);color:#8FA6A3;padding:56px 0 40px;font-size:14px}
footer .top{display:flex;justify-content:space-between;gap:30px;flex-wrap:wrap;margin-bottom:36px}
footer .col h4{color:#fff;font-family:'Space Grotesk';font-size:14px;font-weight:600;margin-bottom:12px}
footer .col a{display:block;padding:4px 0}
footer .col a:hover{color:#fff}
footer .legal{border-top:1px solid rgba(92,184,178,.15);padding-top:24px;font-size:12.5px;color:#5F7472;display:flex;justify-content:space-between;gap:14px;flex-wrap:wrap}

@media(max-width:760px){
  .navlinks{display:none;position:absolute;top:66px;left:0;right:0;background:var(--night);flex-direction:column;padding:18px 22px;gap:16px;border-bottom:1px solid rgba(92,184,178,.2)}
  .navlinks.open{display:flex}
  .burger{display:block}
  .hero .wrap{padding-top:64px;padding-bottom:96px}
  .sechead{display:block}
  .sechead p{max-width:640px;justify-self:start}
  .faq{grid-template-columns:1fr;gap:0}
  section{padding:60px 0}
}
</style>
</head>
<body>

