<script is:inline>
/* ---------- signature: the country comes online ---------- */
(function(){

  /* anchor scrolling: smooth when the browser honours it, instant otherwise */
  document.querySelectorAll('a[href^="#"]').forEach(a => {
    a.addEventListener('click', e => {
      const id = a.getAttribute('href').slice(1);
      const t = id && document.getElementById(id);
      if (!t) return;
      e.preventDefault();
      history.pushState(null, '', '#' + id);
      const y = Math.max(0, t.getBoundingClientRect().top + window.scrollY - 78);
      window.scrollTo({ top: y, behavior: 'smooth' });
      let last = window.scrollY, checks = 0;
      const iv = setInterval(() => {
        const cur = window.scrollY;
        if (Math.abs(cur - y) < 40 || ++checks > 20) { clearInterval(iv); return; }
        if (Math.abs(cur - last) < 2) { clearInterval(iv); window.scrollTo(0, y); return; }
        last = cur;
      }, 180);
      document.querySelector('.navlinks')?.classList.remove('open');
    });
  });


})();


/* ---------- plan tabs + custom bandwidth pricing ---------- */
let planMode='home';
const ANCH={home:[[50,999],[150,1899],[300,3999],[600,5499],[1000,8999]],
            biz:[[50,2999],[150,4499],[300,6999],[600,10499],[1000,14999]]};
function planTab(m){
  planMode=m;
  document.getElementById('grid-home').classList.toggle('on',m==='home');
  document.getElementById('grid-biz').classList.toggle('on',m==='biz');
  document.getElementById('tab-home').classList.toggle('on',m==='home');
  document.getElementById('tab-biz').classList.toggle('on',m==='biz');
  bwCalc();
}
function bwCalc(){
  const v=+document.getElementById('bw').value;
  const a=ANCH[planMode];
  let p=a[a.length-1][1];
  for(let i=0;i<a.length-1;i++){
    if(v>=a[i][0]&&v<=a[i+1][0]){
      const t=(v-a[i][0])/(a[i+1][0]-a[i][0]);
      p=a[i][1]+t*(a[i+1][1]-a[i][1]);break;
    }
  }
  p=Math.round(p/100)*100-1;
  document.getElementById('bwv').textContent=v;
  document.getElementById('bwp').textContent=p.toLocaleString();
  const seg=planMode==='biz'?'business':'home';
  document.getElementById('bwcta').href='https://wa.me/254729267328?text='+encodeURIComponent(`Habari! I'd like a custom ${seg} plan: ${v} Mbps at about KES ${p.toLocaleString()}/month.`);
}
bwCalc();
</script>
