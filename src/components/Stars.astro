{/* Photographic-density night sky. Drop inside any position:relative dark hero. */}
<canvas class="stars" aria-hidden="true"></canvas>
<script is:inline>
(function(){
  const cv = document.currentScript.previousElementSibling;
  if (!cv || cv.tagName !== 'CANVAS' || !cv.getContext) return;
  const host = cv.parentElement;
  function draw(){
    const w = host.clientWidth, h = host.clientHeight;
    if (!w || !h) return;
    const dpr = Math.min(2, window.devicePixelRatio || 1);
    cv.width = Math.round(w*dpr); cv.height = Math.round(h*dpr);
    cv.style.width = w + 'px'; cv.style.height = h + 'px';
    const ctx = cv.getContext('2d');
    ctx.scale(dpr, dpr);
    let seed = 42; const rnd = () => (seed = (seed*9301+49297)%233280)/233280;
    const overCopy = (x,y)=> x > w*.12 && x < w*.72 && y > h*.12 && y < h*.82;

    /* milky-way cloud: soft luminous washes along a diagonal */
    for (let i=0;i<26;i++){
      const t=i/26;
      const bx = w*.08 + t*w*.9 + (rnd()-.5)*w*.06;
      const by = h*.08 + t*h*.5 + (rnd()-.5)*h*.10;
      const rr = 60 + rnd()*150;
      const g = ctx.createRadialGradient(bx,by,0,bx,by,rr);
      g.addColorStop(0, 'rgba(205,230,227,0.028)');
      g.addColorStop(1, 'rgba(205,230,227,0)');
      ctx.fillStyle = g;
      ctx.fillRect(bx-rr,by-rr,rr*2,rr*2);
    }
    function star(x,y,r,a,warm){
      ctx.globalAlpha = a;
      ctx.fillStyle = warm ? '#F2E7D5' : (rnd()<.3 ? '#D6E9F5' : '#E6F2F0');
      ctx.beginPath(); ctx.arc(x,y,r,0,6.2832); ctx.fill();
    }
    const baseN = Math.round(w*h/950);
    for (let i=0;i<baseN;i++){
      const x=rnd()*w, y=rnd()*h;
      let a = .10 + Math.pow(rnd(),1.6)*.42;
      if (overCopy(x,y)) a *= .55;
      star(x, y, .35 + rnd()*.65, a, rnd()<.06);
    }
    const bandN = Math.round(w*h/1900);
    for (let i=0;i<bandN;i++){
      const t=rnd();
      const x = w*.08 + t*w*.9 + (rnd()-.5)*w*.16;
      const y = h*.08 + t*h*.5 + (rnd()-.5)*h*.22;
      if (x<0||x>w||y<0||y>h) continue;
      let a = .08 + Math.pow(rnd(),1.4)*.38;
      if (overCopy(x,y)) a *= .55;
      star(x, y, .3 + rnd()*.55, a);
    }
    const pinN = Math.round(w/9);
    for (let i=0;i<pinN;i++){
      const x=rnd()*w, y=rnd()*h;
      let a = .45 + rnd()*.3;
      if (overCopy(x,y)) a *= .5;
      star(x, y, .7 + rnd()*.5, a);
    }
    ctx.globalAlpha = 1;
  }
  let rt;
  const queue = ()=>{ clearTimeout(rt); rt=setTimeout(draw, 120); };
  draw();
  /* hero height settles after fonts/layout — redraw whenever it changes */
  if (window.ResizeObserver) new ResizeObserver(queue).observe(host);
  if (document.fonts && document.fonts.ready) document.fonts.ready.then(queue);
  addEventListener('load', queue);
  addEventListener('resize', queue);
})();
</script>
